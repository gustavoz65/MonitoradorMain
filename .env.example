# Variavel opcional para mudar a pasta local da CLI.
# Se nao definir, o MoniMaster usa .monimaster no diretorio atual.
MONIMASTER_HOME=.monimaster

# Exemplos de DSN para bancos suportados pela CLI:
# PostgreSQL: postgres://user:pass@localhost:5432/monimaster?sslmode=disable
# MySQL: user:pass@tcp(localhost:3306)/monimaster
# SQLite: monimaster.db
# Oracle: oracle://user:pass@localhost:1521/XEPDB1
